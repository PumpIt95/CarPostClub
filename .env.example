HOST=127.0.0.1
PORT=3911
NODE_ENV=development

UPLOAD_ROOT=/tmp/carpostclub/uploads
TMP_ROOT=/tmp/carpostclub/tmp

CARPOSTCLUB_AUTH_USERNAME=admin
CARPOSTCLUB_AUTH_PASSWORD=change-me-before-deploying
CARPOSTCLUB_AUTH_SESSION_SECRET=replace-with-a-long-random-string
CARPOSTCLUB_AUTH_COOKIE_SECURE=false

# Optional. If unset, stable VAPID keys are generated under the app data directory.
CARPOSTCLUB_PUSH_SUBJECT=mailto:hello@carpostclub.local
CARPOSTCLUB_PUSH_VAPID_PUBLIC_KEY=
CARPOSTCLUB_PUSH_VAPID_PRIVATE_KEY=
CARPOSTCLUB_PUSH_TTL_SECONDS=3600

# Optional. If unset, Facebook Marketplace descriptions use local template fallback copy.
OPENAI_API_KEY=
FACEBOOK_MARKETPLACE_DESCRIPTION_MODEL=gpt-5-nano
FACEBOOK_MARKETPLACE_DESCRIPTION_FALLBACK_MODEL=gpt-4.1-nano
FACEBOOK_MARKETPLACE_DESCRIPTION_VARIANT_COUNT=6
FACEBOOK_MARKETPLACE_LOCATION=Halifax, Nova Scotia
