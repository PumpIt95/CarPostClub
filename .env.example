HOST=127.0.0.1
PORT=3911
NODE_ENV=development

UPLOAD_ROOT=/tmp/konner-upload/uploads
TMP_ROOT=/tmp/konner-upload/tmp

KONNER_AUTH_USERNAME=konner
KONNER_AUTH_PASSWORD=change-me-before-deploying
KONNER_AUTH_SESSION_SECRET=replace-with-a-long-random-string
KONNER_AUTH_COOKIE_SECURE=false

# Optional. If unset, Facebook Marketplace descriptions use local template fallback copy.
OPENAI_API_KEY=
FACEBOOK_MARKETPLACE_DESCRIPTION_MODEL=gpt-5-nano
FACEBOOK_MARKETPLACE_DESCRIPTION_FALLBACK_MODEL=gpt-4.1-nano
FACEBOOK_MARKETPLACE_DESCRIPTION_VARIANT_COUNT=6
FACEBOOK_MARKETPLACE_LOCATION=Halifax, Nova Scotia
