HOST=127.0.0.1
PORT=3911
NODE_ENV=development

UPLOAD_ROOT=/tmp/carpostclub/uploads
TMP_ROOT=/tmp/carpostclub/tmp

# Optional. Defaults to local filesystem media storage under UPLOAD_ROOT.
# Set CARPOSTCLUB_MEDIA_STORAGE_DRIVER=s3 to store uploaded media in S3-compatible object storage.
CARPOSTCLUB_MEDIA_STORAGE_DRIVER=local
CARPOSTCLUB_S3_BUCKET=
CARPOSTCLUB_S3_ENDPOINT=
CARPOSTCLUB_S3_REGION=fsn1
CARPOSTCLUB_S3_PREFIX=
CARPOSTCLUB_S3_ACCESS_KEY_ID=
CARPOSTCLUB_S3_SECRET_ACCESS_KEY=
CARPOSTCLUB_S3_FORCE_PATH_STYLE=false

CARPOSTCLUB_AUTH_USERNAME=admin
CARPOSTCLUB_AUTH_PASSWORD=change-me-before-deploying
CARPOSTCLUB_AUTH_SESSION_SECRET=replace-with-a-long-random-string
CARPOSTCLUB_AUTH_COOKIE_SECURE=false

# Optional. If unset, stable VAPID keys are generated under the app data directory.
CARPOSTCLUB_PUSH_SUBJECT=mailto:hello@carpostclub.local
CARPOSTCLUB_PUSH_VAPID_PUBLIC_KEY=
CARPOSTCLUB_PUSH_VAPID_PRIVATE_KEY=
CARPOSTCLUB_PUSH_TTL_SECONDS=3600

# Server-side sold/offline upload cleanup. Keep disabled/dry-run for local development.
# In production, enable this on only one running app instance.
CARPOSTCLUB_SOLD_UPLOAD_CLEANUP_ENABLED=false
CARPOSTCLUB_SOLD_UPLOAD_CLEANUP_INTERVAL_MS=21600000
CARPOSTCLUB_SOLD_UPLOAD_CLEANUP_STARTUP_DELAY_MS=600000
CARPOSTCLUB_SOLD_UPLOAD_CLEANUP_MAX_DELETIONS_PER_RUN=25
CARPOSTCLUB_SOLD_UPLOAD_CLEANUP_DRY_RUN=true

# Optional. If unset, Facebook Marketplace descriptions use local template fallback copy.
OPENAI_API_KEY=
FACEBOOK_MARKETPLACE_DESCRIPTION_MODEL=gpt-5-nano
FACEBOOK_MARKETPLACE_DESCRIPTION_FALLBACK_MODEL=gpt-4.1-nano
FACEBOOK_MARKETPLACE_DESCRIPTION_VARIANT_COUNT=6
FACEBOOK_MARKETPLACE_LOCATION=Halifax, Nova Scotia
