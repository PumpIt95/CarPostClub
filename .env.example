HOST=127.0.0.1
PORT=3911
NODE_ENV=development
CARPOSTCLUB_PUBLIC_ORIGIN=

UPLOAD_ROOT=/tmp/carpostclub/uploads
TMP_ROOT=/tmp/carpostclub/tmp
CARPOSTCLUB_FACEBOOK_MIN_PHOTO_COUNT=5
CARPOSTCLUB_OREGANS_INVENTORY_SNAPSHOT_INTERVAL_MS=3600000
CARPOSTCLUB_OREGANS_INVENTORY_SNAPSHOT_OFF_HOURS_ENABLED=true
CARPOSTCLUB_OREGANS_INVENTORY_SNAPSHOT_OFF_HOURS_INTERVAL_MS=3600000
CARPOSTCLUB_OREGANS_INVENTORY_SNAPSHOT_DAY_START_HOUR=0
CARPOSTCLUB_OREGANS_INVENTORY_SNAPSHOT_DAY_END_HOUR=24
CARPOSTCLUB_OREGANS_INVENTORY_SNAPSHOT_TIME_ZONE=America/Halifax
CARPOSTCLUB_OREGANS_INVENTORY_SNAPSHOT_RETENTION_DAYS=14
CARPOSTCLUB_OREGANS_INVENTORY_SNAPSHOT_PRUNE_INTERVAL_MS=21600000
# Hold source-removal decisions through brief O'Regan's feed gaps.
CARPOSTCLUB_OREGANS_INVENTORY_REMOVAL_GRACE_MS=172800000

# Optional. Defaults to local filesystem media storage under UPLOAD_ROOT.
# Set CARPOSTCLUB_MEDIA_STORAGE_DRIVER=s3 to store uploaded media in S3-compatible object storage.
CARPOSTCLUB_MEDIA_STORAGE_DRIVER=local
CARPOSTCLUB_S3_BUCKET=
CARPOSTCLUB_S3_ENDPOINT=
CARPOSTCLUB_S3_REGION=fsn1
CARPOSTCLUB_S3_PREFIX=
CARPOSTCLUB_S3_ACCESS_KEY_ID=
CARPOSTCLUB_S3_SECRET_ACCESS_KEY=
CARPOSTCLUB_S3_FORCE_PATH_STYLE=false

CARPOSTCLUB_AUTH_USERNAME=admin
CARPOSTCLUB_AUTH_PASSWORD=
CARPOSTCLUB_AUTH_PASSWORD_HASH=
CARPOSTCLUB_AUTH_SESSION_SECRET=
CARPOSTCLUB_AUTH_COOKIE_SECURE=false
CARPOSTCLUB_AUTH_DISABLED=false
CARPOSTCLUB_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
CARPOSTCLUB_LOGIN_RATE_LIMIT_WINDOW_MS=600000
CARPOSTCLUB_SHORTCUTS_BEARER_TOKEN=
CARPOSTCLUB_AUDIT_LOG_PATH=
CARPOSTCLUB_AUDIT_LOG_LIMIT=1000

# Optional. If unset, stable VAPID keys are generated under the app data directory.
CARPOSTCLUB_PUSH_SUBJECT=mailto:hello@carpostclub.local
CARPOSTCLUB_PUSH_VAPID_PUBLIC_KEY=
CARPOSTCLUB_PUSH_VAPID_PRIVATE_KEY=
CARPOSTCLUB_PUSH_TTL_SECONDS=3600

# Optional. If unset, Facebook Marketplace descriptions use local template fallback copy.
OPENAI_API_KEY=
FACEBOOK_MARKETPLACE_DESCRIPTION_MODEL=gpt-5-nano
FACEBOOK_MARKETPLACE_DESCRIPTION_FALLBACK_MODEL=gpt-4.1-nano
FACEBOOK_MARKETPLACE_DESCRIPTION_VARIANT_COUNT=6
FACEBOOK_MARKETPLACE_LOCATION=Halifax, Nova Scotia
FACEBOOK_MARKETPLACE_POSTAL_CODE=B3K4P9
